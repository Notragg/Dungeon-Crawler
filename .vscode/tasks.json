{
"version": "2.0.0",
"tasks": [
{
"label": "Build Raylib Game",
"type": "shell",
"command": "C:/msys64/mingw64/bin/g++.exe",
"args": [
"-std=c++17",
"${file}",
"-o",
"${fileDirname}/${fileBasenameNoExtension}.exe",
"-I",
"C:/raylib/raylib/src",
"-L",
"C:/raylib/raylib/src",
"-lraylib",
"-lopengl32",
"-lgdi32",
"-lwinmm"
],
"options": {
"cwd": "${fileDirname}"
},
"group": {
"kind": "build",
"isDefault": true
},
"problemMatcher": ["$gcc"]
}
]
}
